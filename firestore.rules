rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // The app currently uses the Firebase Admin SDK on the server, which bypasses 
    // these rules. These are here as defense-in-depth and for future-proofing.

    match /users/{userId} {
      // Allow users to read their own profile if we ever move to client-side reads
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
