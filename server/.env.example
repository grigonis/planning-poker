# Firebase Admin SDK — get from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: Wrap the private key in double quotes to preserve line breaks
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=5000

# CORS — comma-separated list of allowed origins (required in production)
# Example: http://localhost:5173,https://yourapp.com
CORS_ORIGIN=http://localhost:5173
