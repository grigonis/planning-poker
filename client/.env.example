# Firebase Web SDK — get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Backend socket server URL (defaults to http://localhost:5000)
# VITE_SERVER_URL=https://api.yourapp.com

# Optional: where Firebase will redirect email magic links (defaults to window.location.origin/dashboard)
# VITE_FIREBASE_EMAIL_LINK_URL=https://yourapp.com/dashboard
